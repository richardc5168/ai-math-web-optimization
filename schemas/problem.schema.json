{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Curriculum-aligned problem record",
  "description": "Schema for elementary math problems targeting Stage III (grades 5-6) of the national curriculum. Every problem entering main must conform to this schema.",
  "type": "object",
  "required": [
    "id",
    "grade",
    "stage",
    "topic_codes",
    "question",
    "solution",
    "source"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3,
      "description": "Unique problem identifier, e.g. N-6-7-speed-0001"
    },
    "grade": {
      "type": "integer",
      "enum": [5, 6],
      "description": "Grade level (5 or 6)"
    },
    "stage": {
      "type": "string",
      "enum": ["III"],
      "description": "Learning stage per national curriculum"
    },
    "topic_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(n-III|s-III|r-III|d-III|N-[56]|S-[56]|D-[56])"
      },
      "description": "At least one learning-performance code (n-III/s-III/r-III/d-III) and/or content code (N-5-*/N-6-*/S-6-*/D-5-*)"
    },
    "question": {
      "type": "string",
      "minLength": 10,
      "description": "Problem statement in Traditional Chinese"
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "normal", "hard"],
      "description": "Difficulty tier"
    },
    "answer_type": {
      "type": "string",
      "enum": ["integer", "fraction", "decimal", "percent", "unit", "mixed"],
      "description": "Expected answer format"
    },
    "solution": {
      "type": "object",
      "required": ["steps", "answer"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 },
          "description": "Ordered solution steps; each step must be a single verifiable operation"
        },
        "answer": {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "description": "Numeric answer (number or string for fractions)"
            },
            "unit": {
              "type": "string",
              "description": "Answer unit, e.g. 公里, 元, 公升"
            },
            "tolerance": {
              "type": "number",
              "default": 0,
              "description": "Allowed tolerance for approximate answers"
            }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["url", "license_type", "captured_at"],
      "properties": {
        "url": {
          "type": "string",
          "description": "Source URL for traceability"
        },
        "license_type": {
          "type": "string",
          "description": "License type, e.g. CC BY-NC-SA 4.0, public-domain, needs_review"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of source capture"
        },
        "license_decision": {
          "type": "string",
          "enum": ["allow", "deny", "needs_review"],
          "default": "needs_review",
          "description": "Automated or manual license decision"
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Model confidence; < 0.7 triggers human review queue"
    },
    "checks": {
      "type": "object",
      "properties": {
        "must_include_formula": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Formulas that must appear in solution steps"
        },
        "unit_consistency": {
          "type": "boolean",
          "description": "Whether unit consistency check is required"
        },
        "forbidden_words": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Words that must NOT appear (e.g. curriculum restrictions)"
        }
      }
    }
  },
  "additionalProperties": true
}
