{
  "name": "ragweb-exam-sprint-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npm run test:unit",
    "lint": "node tools/run_lint_check.cjs",
    "test:unit": "node tools/run_unit_check.cjs",
    "test:contract": "node tools/validate_questions.cjs",
    "test:property": "node tools/run_property_check.cjs",
    "test:e2e": "node tools/run_e2e_check.cjs",
    "test:axe": "node tools/run_axe_check.cjs",
    "test:lighthouse": "node tools/run_lighthouse_check.cjs",
    "test:visual": "node tools/run_visual_snapshot.cjs",
    "test:diagnosis": "node --test tests_js/diagnoseWrongAnswer.test.mjs",
    "judge:hints": "node tools/judge_hint_quality.cjs golden/grade5_pack_v1.jsonl --out artifacts/hint_judge.json",
    "autotune:hints": "node tools/autotune_hints_json.cjs",
    "derive:report-signals": "node tools/derive_report_signal_candidates.cjs --in feedback/parent_report_signals.jsonl --out artifacts/report_autotune_candidates.json",
    "apply:report-signals": "node tools/apply_report_signal_autotune.cjs --golden golden/grade5_pack_v1.jsonl --candidates artifacts/report_autotune_candidates.json --report artifacts/report_autotune_apply.json",
    "check:improvement": "node tools/check_improvement_trend.cjs --mode enforce",
    "trend:improvement": "node tools/build_improvement_trend_chart.cjs",
    "memory:update": "node tools/update_error_memory.cjs",
    "triage:agent": "node tools/build_agent_triage_report.cjs",
    "agent:web-search": "node tools/agent_web_search_topics.cjs",
    "commands:poll": "node tools/poll_hourly_commands.cjs --watch --interval-min 30",
    "commands:poll:once": "node tools/poll_hourly_commands.cjs --once",
    "commands:poll:7h": "node tools/poll_hourly_commands.cjs --watch --interval-min 5 --max-hours 7",
    "optimize:g5g6:web:5h": "node tools/run_overnight_optimization.cjs --hours 5 --interval-min 30 --auto-push",
    "external:web:ingest": "python tools/external_web_ingest/collect_external_fraction_notes.py --offline",
    "external:web:build": "python tools/external_web_ingest/build_external_fraction_pack.py --n 40 --seed 60223",
    "external:web:validate": "python tools/external_web_ingest/validate_external_fraction_pack.py --pack data/external_web_fraction_app_v1_pack.json",
    "fraction-decimal:web:ingest": "python tools/external_web_ingest/collect_fraction_decimal_notes.py",
    "fraction-decimal:web:build": "python tools/external_web_ingest/build_fraction_decimal_pack.py --n 40 --seed 60224",
    "fraction-decimal:web:validate": "python tools/external_web_ingest/validate_fraction_decimal_pack.py --pack data/fraction_decimal_application_web_v1_pack.json",
    "test:external:fraction": "python -m pytest tests/test_external_web_fraction_pack_loop.py -q",
    "test:fraction-decimal:web": "python -m pytest tests/test_fraction_decimal_application_web_loop.py -q",
    "idle:web:fraction-decimal:expand": "node ops/idle_web_fraction_decimal_expand.cjs",
    "topic:align": "node tools/build_web_topic_alignment_report.cjs",
    "summary:iteration": "node tools/build_iteration_output_summary.cjs",
    "self-heal:verify": "node tools/self_heal_verify.cjs",
    "overnight:optimize": "node tools/run_overnight_optimization.cjs --hours 7 --interval-min 30",
    "golden:check": "node tools/run_golden_correctness.cjs",
    "scorecard": "node tools/build_scorecard.cjs --out artifacts/scorecard.json",
    "gate:scorecard": "node tools/check_scorecard_gate.cjs",
    "verify:all": "node tools/run_verify_all.cjs",
    "verify:kind-coverage": "node tools/verify-kind-coverage.js",
    "status:mail": "python scripts/send_status_email.py"
    ,"login:once": "node tools/tcool_downloader/login_once.js"
    ,"bulk:download": "node tools/tcool_downloader/bulk_download.js"
    ,"organize:teaching": "python tools/tcool_downloader/organize_teaching_focus.py"
    ,"tcool:add-to-bank": "node tools/tcool_downloader/add_pairs_to_national_bank.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "ajv": "^8.17.1",
    "axe-core": "^4.10.3"
  }
}
