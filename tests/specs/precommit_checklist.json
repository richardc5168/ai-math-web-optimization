{
  "version": 1,
  "name": "RAGWEB strict pre-commit checklist",
  "checks": [
    {
      "id": "debug_note_present",
      "type": "file_exists",
      "enabled": true,
      "path": "debug_note.txt",
      "contains": [
        "GitHub Pages",
        "docs/ 與 dist_ai_math_web_pages/docs",
        "offline-math",
        "回朔"
      ]
    },
    {
      "id": "docs_dist_identical",
      "type": "docs_dist_identical",
      "enabled": true
    },
    {
      "id": "offline_math_bank_present",
      "type": "file_exists",
      "enabled": true,
      "path": "docs/offline-math/bank.js",
      "contains": [
        "window.OFFLINE_MATH_BANK"
      ]
    },
    {
      "id": "offline_math_compat_aggregate_present",
      "type": "file_exists",
      "enabled": true,
      "path": "docs/offline-math/aggregate_compat.js",
      "contains": [
        "window.AIMathReportAggregate"
      ]
    },
    {
      "id": "offline_math_page_assets_linked",
      "type": "file_exists",
      "enabled": true,
      "path": "docs/offline-math/index.html",
      "contains": [
        "./aggregate_compat.js?v=1",
        "./bank.js?v=3"
      ]
    },
    {
      "id": "offline_math_no_eval_bank_loader",
      "type": "forbid_string",
      "enabled": true,
      "globs": [
        "docs/offline-math/index.html",
        "dist_ai_math_web_pages/docs/offline-math/index.html"
      ],
      "forbid": [
        "Function(t)()",
        "fetch('./bank.js",
        "fetch(\"./bank.js"
      ],
      "message": "Do not load bank.js via fetch+Function/eval style. Use a script tag to avoid CSP/compat blank-screen regressions."
    },
    {
      "id": "offline_math_no_optional_chaining",
      "type": "forbid_string",
      "enabled": true,
      "globs": [
        "docs/offline-math/index.html",
        "docs/shared/attempt_telemetry.js",
        "docs/offline-math/aggregate_compat.js",
        "dist_ai_math_web_pages/docs/offline-math/index.html",
        "dist_ai_math_web_pages/docs/shared/attempt_telemetry.js",
        "dist_ai_math_web_pages/docs/offline-math/aggregate_compat.js"
      ],
      "forbid": [
        "?."
      ],
      "message": "Optional chaining (?.) can cause a syntax error and blank screen on older embedded browsers. Keep offline-math critical scripts compatible."
    },
    {
      "id": "api_smoke",
      "type": "api_smoke",
      "enabled": true,
      "paths": [
        "/health",
        "/verify",
        "/quadratic",
        "/mixed-multiply"
      ]
    },
    {
      "id": "no_root_home_links",
      "type": "forbid_string",
      "enabled": true,
      "globs": [
        "docs/**/*.html",
        "dist_ai_math_web_pages/docs/**/*.html"
      ],
      "forbid": [
        "https://richardc5168.github.io/ai-math-web/",
        "href=\"/ai-math-web/\"",
        "href='/ai-math-web/'"
      ],
      "message": "Avoid linking to repo root (/) because it uses location.replace + meta refresh, which can break browser back navigation. Link to the docs dashboard (../) instead."
    },
    {
      "id": "pytest_subset",
      "type": "pytest",
      "enabled": true,
      "args": [
        "-q",
        "tests/test_question_bank_validation.py",
        "tests/test_report_aggregate_mvp.py"
      ]
    }
  ]
}
